<ui:FluentWindow x:Class="Utterheim.Views.BootstrapDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Utterheim — first run"
                 Width="560" Height="380"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Utterheim — first run" />

        <Grid Grid.Row="1" Margin="32,16,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Setting up Utterheim"
                       FontSize="22"
                       FontWeight="Light"
                       Margin="0,0,0,8" />

            <TextBlock Grid.Row="1"
                       Text="Utterheim needs to download a small Python runtime and the pocket-tts speech model. This is a one-time setup (~700 MB total)."
                       TextWrapping="Wrap"
                       Opacity="0.75"
                       Margin="0,0,0,20" />

            <StackPanel Grid.Row="2" VerticalAlignment="Top">
                <TextBlock x:Name="StatusText"
                           Text="Preparing…"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="DetailText"
                           Text=""
                           FontSize="11"
                           Opacity="0.55"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
            </StackPanel>

            <ProgressBar Grid.Row="3"
                         x:Name="OverallProgress"
                         Height="6"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Margin="0,0,0,8" />

            <TextBlock Grid.Row="4"
                       x:Name="StepCounter"
                       Text="Step 1 of 4"
                       FontSize="11"
                       Opacity="0.55"
                       Margin="0,0,0,16" />

            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button x:Name="RetryButton"
                           Content="Retry"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Visibility="Collapsed"
                           Margin="0,0,8,0"
                           Click="RetryButton_Click" />
                <ui:Button x:Name="ActionButton"
                           Content="Cancel"
                           Width="120"
                           Click="ActionButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
