<ui:FluentWindow x:Class="Utterheim.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
                 xmlns:pages="clr-namespace:Utterheim.Views.Pages"
                 Title="Utterheim — Local voices for Claude Code"
                 Width="900" Height="820"
                 Icon="pack://application:,,,/Resources/utterheim.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <Style x:Key="BrandMarkStyle" TargetType="Viewbox">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>
        <!-- main-033: nav items mirror WhisperHeim — uppercase label, FontSize=11,
             FontWeight=Medium. Applied as an implicit style scoped to the
             NavigationView so Speak/Voices/Settings/About all match. -->
        <Style x:Key="NavItemStyle" TargetType="ui:NavigationViewItem">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ContentPresenter that hosts wpfui ContentDialogs (main-026 + future).
             Spans the nav-area row so the modal overlay covers the page surface. -->
        <ContentPresenter x:Name="RootContentDialogPresenter"
                          Grid.Row="1"
                          Panel.ZIndex="100" />

        <ui:TitleBar Grid.Row="0" Title="Utterheim" />

        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.Row="0"
                         FocusOnLeftClick="False"
                         MenuOnRightClick="True"
                         Icon="pack://application:,,,/Resources/utterheim.ico"
                         TooltipText="Utterheim — Local voices for Claude Code"
                         LeftClick="TrayIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem Header="Show window" Click="TrayShow_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Window24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <ui:MenuItem Header="Stop speaking" Click="TrayStop_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Stop24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="TrayExit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           OpenPaneLength="220">
            <ui:NavigationView.PaneHeader>
                <!-- main-033: sidebar header mirrors WhisperHeim's BrandingHeader —
                     same brand mark (utterheim-logo-256.png) used by BrandHeroControl
                     on the Speak page, beside the "Utterheim" wordmark in 16pt Bold.
                     The previous inline-drawn portrait is gone. -->
                <StackPanel Orientation="Horizontal" Margin="12,12,12,16">
                    <Viewbox Width="28" Height="28" VerticalAlignment="Center"
                             Style="{StaticResource BrandMarkStyle}">
                        <Image Source="pack://application:,,,/assets/branding/utterheim-logo-256.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Viewbox>
                    <TextBlock Text="Utterheim"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </StackPanel>
            </ui:NavigationView.PaneHeader>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="SPEAK"
                                       Style="{StaticResource NavItemStyle}"
                                       TargetPageType="{x:Type pages:SpeakPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Mic24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="VOICES"
                                       Style="{StaticResource NavItemStyle}"
                                       TargetPageType="{x:Type pages:VoicesPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="PersonVoice24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="SETTINGS"
                                       Style="{StaticResource NavItemStyle}"
                                       TargetPageType="{x:Type pages:SettingsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <!-- About sits in the footer menu (bottom-left of the nav pane)
                 like WhisperHeim — main-032 separates identity / credits from
                 the everyday speak / voices / settings flow. -->
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="ABOUT"
                                       Style="{StaticResource NavItemStyle}"
                                       TargetPageType="{x:Type pages:AboutPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <Border x:Name="StatusFooter"
                Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,4"
                MinHeight="28">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0.85">
                <Run Text="HTTP " /><Run Text="{Binding HttpEndpoint, FallbackValue='—'}" /><Run Text="  •  Engine: " /><Run Text="{Binding EngineState, FallbackValue='—'}" />
            </TextBlock>
        </Border>
    </Grid>
</ui:FluentWindow>
