<ui:ContentDialog x:Class="Mockingbird.Views.Dialogs.DeleteVoiceDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  Title=""
                  IsFooterVisible="False"
                  DialogWidth="420">
    <!-- BoolToVisibilityConverter + NullOrEmptyToVisibilityConverter are
         registered once in App.xaml as of main-032 — no local Resources
         block needed any more. -->


    <StackPanel Margin="8">
        <!-- Icon + Title row (matches WhisperHeim's DeleteConfirmationDialog) -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="40" Height="40" CornerRadius="10"
                    Background="#20E81224" Margin="0,0,14,0">
                <ui:SymbolIcon Symbol="Delete24"
                               Foreground="#FFE81224"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Delete voice?"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="This action cannot be undone."
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Voice name card -->
        <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,16">
            <TextBlock Text="{Binding VoiceName}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Inline error (shown only when DeleteAsync failed) -->
        <TextBlock Text="{Binding ErrorMessage}"
                   FontSize="12"
                   Foreground="#FFE81224"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}" />

        <!-- Right-aligned Cancel + Delete -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Cancel"
                       Appearance="Secondary"
                       Padding="20,8"
                       Margin="0,0,8,0"
                       Command="{Binding CancelCommand}" />
            <ui:Button Padding="20,8"
                       Command="{Binding DeleteCommand}"
                       Foreground="White"
                       BorderThickness="0">
                <ui:Button.Template>
                    <ControlTemplate TargetType="{x:Type ui:Button}">
                        <Border CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                Background="#FFE81224">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </ui:Button.Template>
                <StackPanel Orientation="Horizontal">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="14" Height="14"
                                     Margin="0,0,8,0"
                                     Foreground="White"
                                     Visibility="{Binding IsDeleting, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <TextBlock Text="Delete"
                               Foreground="White"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
        </StackPanel>
    </StackPanel>
</ui:ContentDialog>
