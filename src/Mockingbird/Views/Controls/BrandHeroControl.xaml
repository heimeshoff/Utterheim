<UserControl x:Class="Mockingbird.Views.Controls.BrandHeroControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="HeroRoot">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <!-- Hero composition matches WhisperHeim's AboutPage hero exactly:
         88x88 logo badge (brand-blue border + 10% brand-blue tint), then the
         app name in ExtraBold 40pt with the version tagged beside it in
         BrandDeepMutedBrush, then an optional tagline TextBlock that collapses
         when Tagline is null/empty. main-030 ships the control; reused by
         main-032's About page redesign. -->
    <StackPanel HorizontalAlignment="Center"
                Margin="0,20,0,32">

        <!-- Logo badge -->
        <Border Width="88" Height="88"
                CornerRadius="18"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                BorderThickness="3"
                BorderBrush="{StaticResource BrandPrimaryBrush}"
                Background="#1025abfe">
            <Image Source="pack://application:,,,/assets/branding/mockingbird-logo-256.png"
                   Margin="6"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>

        <!-- App name + version -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <TextBlock Text="Mockingbird"
                       FontSize="40"
                       FontWeight="ExtraBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock x:Name="VersionText"
                       FontSize="18"
                       FontWeight="Medium"
                       Foreground="{StaticResource BrandDeepMutedBrush}"
                       VerticalAlignment="Top"
                       Margin="8,8,0,0" />
        </StackPanel>

        <!-- Optional tagline — collapsed when Tagline DP is null/empty -->
        <TextBlock x:Name="TaglineText"
                   FontSize="14"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="460"
                   Text="{Binding Tagline, ElementName=HeroRoot}"
                   Visibility="{Binding HasTagline, ElementName=HeroRoot, Converter={StaticResource BoolToVisibilityConverter}}" />
    </StackPanel>
</UserControl>
