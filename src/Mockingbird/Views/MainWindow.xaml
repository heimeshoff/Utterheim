<ui:FluentWindow x:Class="Mockingbird.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
                 xmlns:pages="clr-namespace:Mockingbird.Views.Pages"
                 Title="Mockingbird — Local voices for Claude Code"
                 Width="900" Height="820"
                 Icon="pack://application:,,,/Resources/mockingbird.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <Style x:Key="BrandMarkStyle" TargetType="Viewbox">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ContentPresenter that hosts wpfui ContentDialogs (main-026 + future).
             Spans the nav-area row so the modal overlay covers the page surface. -->
        <ContentPresenter x:Name="RootContentDialogPresenter"
                          Grid.Row="1"
                          Panel.ZIndex="100" />

        <ui:TitleBar Grid.Row="0" Title="Mockingbird" />

        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.Row="0"
                         FocusOnLeftClick="False"
                         MenuOnRightClick="True"
                         Icon="pack://application:,,,/Resources/mockingbird.ico"
                         TooltipText="Mockingbird — Local voices for Claude Code"
                         LeftClick="TrayIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem Header="Show window" Click="TrayShow_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Window24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <ui:MenuItem Header="Stop speaking" Click="TrayStop_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Stop24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="TrayExit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           OpenPaneLength="220">
            <ui:NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Margin="12,12,12,16">
                    <Viewbox Width="28" Height="28" Style="{StaticResource BrandMarkStyle}">
                        <Canvas Width="256" Height="256">
                            <Ellipse Canvas.Left="62" Canvas.Top="46" Width="60" Height="60"
                                     Fill="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Path Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                  Data="M 44 196 Q 52 132 92 124 Q 132 132 140 196 Z" />
                            <Path Stroke="{DynamicResource TextFillColorPrimaryBrush}" StrokeThickness="10"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 138 76 Q 158 56 158 76 Q 158 96 138 76" />
                            <Path Stroke="{DynamicResource TextFillColorPrimaryBrush}" StrokeThickness="10"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 168 76 Q 196 46 196 76 Q 196 106 168 76" />
                            <Path Stroke="{DynamicResource TextFillColorPrimaryBrush}" StrokeThickness="10"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 198 76 Q 234 36 234 76 Q 234 116 198 76" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Mockingbird"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                </StackPanel>
            </ui:NavigationView.PaneHeader>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Speak"
                                       TargetPageType="{x:Type pages:SpeakPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Mic24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Voices"
                                       TargetPageType="{x:Type pages:VoicesPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="PersonVoice24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Settings"
                                       TargetPageType="{x:Type pages:SettingsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <!-- About sits in the footer menu (bottom-left of the nav pane)
                 like WhisperHeim — main-032 separates identity / credits from
                 the everyday speak / voices / settings flow. -->
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="About"
                                       TargetPageType="{x:Type pages:AboutPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <Border x:Name="StatusFooter"
                Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,4"
                MinHeight="28">
            <TextBlock VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0.85">
                <Run Text="HTTP " /><Run Text="{Binding HttpEndpoint, FallbackValue='—'}" /><Run Text="  •  Engine: " /><Run Text="{Binding EngineState, FallbackValue='—'}" />
            </TextBlock>
        </Border>
    </Grid>
</ui:FluentWindow>
