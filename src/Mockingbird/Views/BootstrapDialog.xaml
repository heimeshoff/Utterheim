<ui:FluentWindow x:Class="Mockingbird.Views.BootstrapDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Mockingbird — first run"
                 Width="500" Height="280"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Mockingbird — first run" />

        <StackPanel Grid.Row="1" Margin="40" VerticalAlignment="Center">
            <TextBlock Text="Mockingbird is ready"
                       FontSize="22"
                       FontWeight="Light"
                       Margin="0,0,0,12" />
            <TextBlock Text="The walking skeleton uses a stubbed engine that plays a 440 Hz test tone instead of synthesised speech. The real pocket-tts model + Python runtime bootstrap lands in a follow-up task (main-011)."
                       TextWrapping="Wrap"
                       Opacity="0.8"
                       Margin="0,0,0,24" />
            <ui:Button Content="Continue"
                       Icon="{ui:SymbolIcon ArrowRight24}"
                       Appearance="Primary"
                       HorizontalAlignment="Right"
                       Click="Continue_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
