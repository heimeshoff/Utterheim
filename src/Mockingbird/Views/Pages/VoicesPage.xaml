<Page x:Class="Mockingbird.Views.Pages.VoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Voices">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 1. header / section title + count -->
            <RowDefinition Height="Auto" />
            <!-- 2. scrollable list (or loading / failed placeholder) -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Voices"
                       FontSize="28"
                       FontWeight="Light" />
            <TextBlock Text="{Binding ViewModel.TotalCount, StringFormat={}{0} voices, FallbackValue='loading…'}"
                       FontSize="12"
                       Margin="0,2,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Loading placeholder (Engine: starting / restarting / not started) -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
            <ui:ProgressRing IsIndeterminate="True"
                             Width="48" Height="48"
                             HorizontalAlignment="Center" />
            <TextBlock Text="Voice engine is starting..."
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Failed banner (Engine: failed) -->
        <Border Grid.Row="1"
                VerticalAlignment="Top"
                Padding="12"
                CornerRadius="4"
                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                BorderThickness="1"
                Visibility="{Binding ViewModel.IsFailed, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
            <TextBlock Text="Voice engine failed to start. See the About page for details and retry."
                       TextWrapping="Wrap" />
        </Border>

        <!-- Voice list (Engine: running) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding ViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel>
                <!-- Built-in voices section -->
                <TextBlock Text="Built-in"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ViewModel.BuiltInVoices}"
                              Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,12"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Column 1: name + meta -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding Meta}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <!-- Column 2: Preview button -->
                                    <ui:Button Grid.Column="1"
                                               Content="Preview"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Play24}"
                                               Command="{Binding PreviewCommand}"
                                               Margin="8,0,8,0"
                                               VerticalAlignment="Center" />

                                    <!-- Column 3: active-request indicator -->
                                    <ui:SymbolIcon Grid.Column="2"
                                                   Symbol="Speaker224"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsActiveRequest, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Cloned voices section -->
                <TextBlock Text="Cloned"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock Text="No cloned voices yet — see main-015 to clone your own."
                           FontSize="12"
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding ViewModel.ClonedSectionIsEmpty, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Visible}" />
                <ItemsControl ItemsSource="{Binding ViewModel.ClonedVoices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,12"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding Meta}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                               Content="Preview"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Play24}"
                                               Command="{Binding PreviewCommand}"
                                               Margin="8,0,8,0"
                                               VerticalAlignment="Center" />

                                    <ui:SymbolIcon Grid.Column="2"
                                                   Symbol="Speaker224"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsActiveRequest, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
