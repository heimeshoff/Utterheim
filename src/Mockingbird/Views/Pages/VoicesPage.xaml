<Page x:Class="Mockingbird.Views.Pages.VoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Mockingbird.ViewModels.Pages"
      Title="Voices">
    <Page.Resources>
        <!-- BoolToVisibilityConverter + NullOrEmptyToVisibilityConverter are
             registered once in App.xaml as of main-032; only the local
             cloning-source converter stays here. -->
        <vm:CloningSourceToBoolConverter x:Key="CloningSourceToBoolConverter" />
    </Page.Resources>

    <ScrollViewer Background="{DynamicResource ApplicationBackgroundBrush}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,36,40,32"
                    MaxWidth="900"
                    HorizontalAlignment="Center">

            <!-- Page title — small Light/28 heading per main-029, no big hero
                 (the big hero is reserved for Speak + About per main-030). -->
            <TextBlock Text="Voices"
                       FontSize="28"
                       FontWeight="Light"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="{Binding ViewModel.TotalCount, StringFormat={}{0} voices, FallbackValue='loading…'}"
                       FontSize="12"
                       Margin="0,2,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- Loading placeholder (Engine: starting / restarting / not started) -->
            <StackPanel HorizontalAlignment="Center"
                        Margin="0,32,0,0"
                        Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="48" Height="48"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="Voice engine is starting..."
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Failed banner (Engine: failed) -->
            <Border Padding="12"
                    CornerRadius="4"
                    Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                    BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                    BorderThickness="1"
                    Margin="0,8,0,0"
                    Visibility="{Binding ViewModel.IsFailed, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="Voice engine failed to start. See the About page for details and retry."
                           TextWrapping="Wrap" />
            </Border>

            <!-- main-030 swap: Clone card moves ABOVE the voice list — clone first,
                 browse second. Styled as a single WhisperHeim card (Border, CornerRadius=12,
                 Padding=24) per the styleguide §Card spec. Visible only while the
                 engine is running. -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,24"
                    Visibility="{Binding ViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Clone a new voice"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <!-- Source toggle: Microphone | System Audio -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <RadioButton GroupName="CloningSource"
                                     IsChecked="{Binding ViewModel.Cloning.SelectedSource, Mode=TwoWay,
                                                Converter={StaticResource CloningSourceToBoolConverter},
                                                ConverterParameter=Microphone}"
                                     Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Mic24" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Microphone" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="CloningSource"
                                     IsChecked="{Binding ViewModel.Cloning.SelectedSource, Mode=TwoWay,
                                                Converter={StaticResource CloningSourceToBoolConverter},
                                                ConverterParameter=SystemAudio}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Speaker224" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="System Audio" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Mic device selector -->
                    <ComboBox ItemsSource="{Binding ViewModel.Cloning.MicDevices}"
                              SelectedItem="{Binding ViewModel.Cloning.SelectedMicDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,8"
                              Visibility="{Binding ViewModel.Cloning.IsMicMode, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />

                    <!-- Loopback device selector -->
                    <ComboBox ItemsSource="{Binding ViewModel.Cloning.LoopbackDevices}"
                              SelectedItem="{Binding ViewModel.Cloning.SelectedLoopbackDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,8"
                              Visibility="{Binding ViewModel.Cloning.IsSystemAudioMode, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />

                    <!-- Tip -->
                    <TextBlock Text="{Binding ViewModel.Cloning.TipText}"
                               FontSize="11"
                               Margin="0,0,0,12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <!-- Audio level meter + duration display -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0"
                                     Minimum="0" Maximum="1.0"
                                     Value="{Binding ViewModel.Cloning.RmsLevel, Mode=OneWay}"
                                     Height="8"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ViewModel.Cloning.DurationLabel, FallbackValue='00:00'}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Progress bar (0..5 s minimum-duration window) -->
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding ViewModel.Cloning.ProgressPercent, Mode=OneWay}"
                                 Height="4"
                                 Margin="0,0,0,12" />

                    <!-- Voice name input + inline error -->
                    <ui:TextBox PlaceholderText="Voice name (e.g. Marco)"
                                Text="{Binding ViewModel.Cloning.VoiceName, UpdateSourceTrigger=PropertyChanged}"
                                MaxLength="40"
                                Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ViewModel.Cloning.VoiceNameError}"
                               FontSize="11"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Visibility="{Binding ViewModel.Cloning.VoiceNameError, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}" />

                    <!-- Status / error message -->
                    <Border Padding="8"
                            CornerRadius="4"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Margin="0,0,0,8"
                            Visibility="{Binding ViewModel.Cloning.StatusMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                        <StackPanel>
                            <TextBlock Text="{Binding ViewModel.Cloning.StatusMessage}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ViewModel.Cloning.StatusDetail}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ViewModel.Cloning.StatusDetail, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}" />
                        </StackPanel>
                    </Border>

                    <!-- Start / Stop / Cancel / Save button row -->
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Start"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Mic24}"
                                   Command="{Binding ViewModel.Cloning.StartCommand}"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="Stop"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Stop24}"
                                   Command="{Binding ViewModel.Cloning.StopCommand}"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="Cancel"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Dismiss24}"
                                   Command="{Binding ViewModel.Cloning.CancelCommand}"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding ViewModel.Cloning.CanCancel, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                        <ui:Button Appearance="Primary"
                                   Command="{Binding ViewModel.Cloning.SaveCommand}"
                                   Margin="0,0,8,0">
                            <ui:Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <ui:ProgressRing IsIndeterminate="True"
                                                     Width="16" Height="16"
                                                     Margin="0,0,8,0"
                                                     Visibility="{Binding ViewModel.Cloning.SaveCommand.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                    <ui:SymbolIcon Symbol="Save24" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Save Voice" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button.Content>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Voice list (Engine: running) — now BELOW the clone card per main-030 -->
            <StackPanel Visibility="{Binding ViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <!-- Built-in voices section -->
                <TextBlock Text="Built-in"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ViewModel.BuiltInVoices}"
                              Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,12"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding Meta}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                               Content="Preview"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Play24}"
                                               Command="{Binding PreviewCommand}"
                                               Margin="8,0,8,0"
                                               VerticalAlignment="Center" />

                                    <ui:SymbolIcon Grid.Column="2"
                                                   Symbol="Speaker224"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsActiveRequest, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Cloned voices section -->
                <TextBlock Text="Cloned"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock Text="No cloned voices yet — clone one above."
                           FontSize="12"
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding ViewModel.ClonedSectionIsEmpty, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Visible}" />
                <ItemsControl ItemsSource="{Binding ViewModel.ClonedVoices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,12"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- main-026: 4-column layout for cloned rows.
                                             name+meta | Preview | Delete | active indicator -->
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding Meta}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                               Content="Preview"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Play24}"
                                               Command="{Binding PreviewCommand}"
                                               Margin="8,0,8,0"
                                               VerticalAlignment="Center" />

                                    <ui:Button Grid.Column="2"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Delete24}"
                                               Command="{Binding DeleteCommand}"
                                               ToolTip="Delete voice"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />

                                    <ui:SymbolIcon Grid.Column="3"
                                                   Symbol="Speaker224"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsActiveRequest, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
