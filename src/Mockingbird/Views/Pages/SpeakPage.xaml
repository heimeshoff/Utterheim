<Page x:Class="Mockingbird.Views.Pages.SpeakPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Mockingbird.Views.Controls"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      Title="Speak">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <!-- main-030 layout: hero on top, single controls row (voice + Play +
         Stop + Save) above the text input, text input fills the remaining
         vertical space, status line at the bottom. The page root is a Grid
         (not a ScrollViewer) so the * row can actually expand and the
         textbox dominates as on WhisperHeim's TTS pane. Outer margin /
         MaxWidth match the styleguide's page chrome (40,36,40,32 / 900). -->
    <Grid Margin="40,36,40,32"
          MaxWidth="900"
          HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <!-- 1. Hero (logo + name + version, no tagline) -->
            <RowDefinition Height="Auto" />
            <!-- 2. Controls row: voice picker + Play + Stop + Save -->
            <RowDefinition Height="Auto" />
            <!-- 3. Text input fills remaining space -->
            <RowDefinition Height="*" />
            <!-- 4. Status line -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. Hero — no tagline; the tagline is reserved for About per main-032 -->
        <controls:BrandHeroControl Grid.Row="0" />

        <!-- 2. Controls row — voice picker on the left, then Play / Stop / Save
             in WhisperHeim TTS order with no separator gap before Save. -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <ComboBox ItemsSource="{Binding ViewModel.Voices}"
                      SelectedItem="{Binding ViewModel.SelectedVoice, Mode=TwoWay}"
                      DisplayMemberPath="Id"
                      MinWidth="240"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0" />
            <ui:Button Content="Play"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Mic24}"
                       Command="{Binding ViewModel.PlayCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Content="Stop"
                       Appearance="Secondary"
                       Icon="{ui:SymbolIcon Stop24}"
                       Command="{Binding ViewModel.StopCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Appearance="Secondary"
                       Command="{Binding ViewModel.SaveCommand}">
                <ui:Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <ui:ProgressRing IsIndeterminate="True"
                                         Width="16" Height="16"
                                         Margin="0,0,8,0"
                                         Visibility="{Binding ViewModel.SaveCommand.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                        <TextBlock Text="Save" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button.Content>
            </ui:Button>
        </StackPanel>

        <!-- 3. Text input — fills the * row. AcceptsReturn preserved; MinHeight
             raised so the row doesn't get pushed off-screen on small windows. -->
        <ui:TextBox Grid.Row="2"
                    Text="{Binding ViewModel.Text, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Type or paste something for Mockingbird to say..."
                    AcceptsReturn="True"
                    AcceptsTab="False"
                    TextWrapping="Wrap"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    VerticalContentAlignment="Top"
                    VerticalScrollBarVisibility="Auto"
                    MinHeight="240"
                    Margin="0,0,0,12" />

        <!-- 4. Status line -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ViewModel.StatusLabel, FallbackValue='idle'}"
                   FontSize="12"
                   Opacity="0.85" />
    </Grid>
</Page>
