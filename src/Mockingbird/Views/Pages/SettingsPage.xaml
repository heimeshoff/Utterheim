<Page x:Class="Mockingbird.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      Title="Settings">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,36,40,32"
                    MaxWidth="900"
                    HorizontalAlignment="Center">

            <!-- Page title -->
            <TextBlock Text="Settings"
                       FontSize="28"
                       FontWeight="Light"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,24" />

            <!-- ═══════ Audio Section ═══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="Speaker224"
                               FontSize="24"
                               Foreground="{StaticResource BrandDeepBrush}"
                               Margin="0,0,10,0" />
                <TextBlock Text="AUDIO"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Default voice -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="Default voice"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Pre-selected on the Speak page. Empty = no preference (alphabetical fallback)."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding ViewModel.Voices}"
                              SelectedItem="{Binding ViewModel.SelectedDefaultVoice, Mode=TwoWay}"
                              DisplayMemberPath="Id"
                              MinWidth="200"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Output device (last card in Audio — 40-px bottom margin) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,40">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="Output device"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Where Mockingbird routes speech. Takes effect on the next speech request."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding ViewModel.OutputDevices}"
                              SelectedItem="{Binding ViewModel.SelectedOutputDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              MinWidth="240"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- ═══════ App Section ═══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="Power24"
                               FontSize="24"
                               Foreground="{StaticResource BrandDeepBrush}"
                               Margin="0,0,10,0" />
                <TextBlock Text="APP"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Start minimised -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="Start minimised"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="When on, Mockingbird launches hidden in the tray."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch DockPanel.Dock="Right"
                                     IsChecked="{Binding ViewModel.StartMinimised, Mode=TwoWay}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Launch at startup (last card in App — 40-px bottom margin) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,40">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="Launch at startup"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Adds Mockingbird to your Windows logon entries (registry)."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch DockPanel.Dock="Right"
                                     IsChecked="{Binding ViewModel.LaunchAtStartup, Mode=TwoWay}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- ═══════ Diagnostics Section ═══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="Wrench24"
                               FontSize="24"
                               Foreground="{StaticResource BrandDeepBrush}"
                               Margin="0,0,10,0" />
                <TextBlock Text="DIAGNOSTICS"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- HTTP port (read-only in v1) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="HTTP port"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="The localhost endpoint Claude Code calls. Read-only in v1."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ViewModel.HttpEndpoint, FallbackValue='—'}"
                               FontFamily="Consolas"
                               FontSize="13"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Stop hotkey (read-only per ADR 0006) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="Stop hotkey"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Halts current speech and drains the queue (ADR 0004)."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ViewModel.StopHotkeyLabel, FallbackValue='—'}"
                               FontSize="13"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- Data path (stacked-content card; main-031) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Data path"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Where voices are stored (per bootstrap.json, ADR 0005). Existing voices stay at the old location."
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,4,0,16"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ViewModel.DataPath, FallbackValue='—'}"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Browse..."
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Folder24}"
                                   Command="{Binding ViewModel.BrowseDataPathCommand}"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="Reset"
                                   Appearance="Secondary"
                                   Command="{Binding ViewModel.ResetDataPathCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Engine status (relocated from About in main-032) — same panel
                 composition main-017 landed: state pip + label, port, healthy
                 indicator (only while Running), last-error block, Restart Engine
                 button. Bound through the composed EngineStatus sub-VM. -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Engine status"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <!-- State row: pip + label -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="State"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource EngineStateToPipBrushConverter}">
                                        <Binding Path="ViewModel.EngineStatus.EngineState" />
                                        <Binding Path="ViewModel.EngineStatus.Healthy" />
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding ViewModel.EngineStatus.EngineStateLabel, FallbackValue='—'}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Port row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Port"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ViewModel.EngineStatus.PortLabel, FallbackValue='—'}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Healthy row (only visible while Running) -->
                    <Grid Margin="0,0,0,8"
                          Visibility="{Binding ViewModel.EngineStatus.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Healthy"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="CheckmarkCircle24"
                                       FontSize="16"
                                       Foreground="#10B981"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ViewModel.EngineStatus.Healthy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="DismissCircle24"
                                       FontSize="16"
                                       Foreground="#FFE81224"
                                       VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.EngineStatus.Healthy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Grid>

                    <!-- Last error block (visible when LastError is non-null) -->
                    <Border BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8"
                            Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                            Visibility="{Binding ViewModel.EngineStatus.LastError, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                        <StackPanel>
                            <TextBlock Text="Last error"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding ViewModel.EngineStatus.LastError}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Restart button -->
                    <ui:Button Appearance="Primary"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding ViewModel.EngineStatus.RestartEngineCommand}"
                               IsEnabled="{Binding ViewModel.EngineStatus.IsRetryEnabled, FallbackValue=False}"
                               HorizontalAlignment="Left"
                               Margin="0,4,0,0">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <ui:ProgressRing IsIndeterminate="True"
                                                 Width="14" Height="14"
                                                 Margin="0,0,8,0"
                                                 Visibility="{Binding ViewModel.EngineStatus.RestartEngineCommand.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                <TextBlock Text="Restart Engine" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>
                </StackPanel>
            </Border>

            <!-- View logs (last item in Diagnostics — 40-px bottom margin
                 separates the section from Appearance below). -->
            <ui:HyperlinkButton Content="View logs"
                                Command="{Binding ViewModel.EngineStatus.OpenLogsCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,40" />

            <!-- ═══════ Appearance Section ═══════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="PaintBrush24"
                               FontSize="24"
                               Foreground="{StaticResource BrandDeepBrush}"
                               Margin="0,0,10,0" />
                <TextBlock Text="APPEARANCE"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Appearance picker (last card of the last section — 40-px bottom margin) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,40">
                <StackPanel>
                    <TextBlock Text="Choose your preferred color scheme."
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,20" />
                    <UniformGrid Columns="3">
                        <!-- Light theme -->
                        <Border x:Name="ThemeLight" Margin="0,0,8,0" Cursor="Hand"
                                Background="Transparent" CornerRadius="12" Padding="12"
                                MouseLeftButtonUp="ThemeLight_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="80" Height="52" CornerRadius="8"
                                        Background="#FFF9F9F9" Margin="0,0,0,8"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" />
                                <TextBlock Text="LIGHT" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                        <!-- Dark theme -->
                        <Border x:Name="ThemeDark" Margin="4,0" Cursor="Hand"
                                Background="Transparent" CornerRadius="12" Padding="12"
                                MouseLeftButtonUp="ThemeDark_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="80" Height="52" CornerRadius="8"
                                        Background="#FF2F3131" Margin="0,0,0,8"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" />
                                <TextBlock Text="DARK" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                        <!-- System theme -->
                        <Border x:Name="ThemeSystem" Margin="8,0,0,0" Cursor="Hand"
                                Background="Transparent" CornerRadius="12" Padding="12"
                                MouseLeftButtonUp="ThemeSystem_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="80" Height="52" CornerRadius="8" Margin="0,0,0,8"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFF9F9F9" Offset="0" />
                                            <GradientStop Color="#FF2F3131" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="SYSTEM" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
