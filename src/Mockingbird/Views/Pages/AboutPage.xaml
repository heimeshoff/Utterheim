<Page x:Class="Mockingbird.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Mockingbird.Views.Controls"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      Title="About">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,36,40,32"
                    MaxWidth="900"
                    HorizontalAlignment="Center">

            <!-- ═══════ 1. Hero ═══════
                 BrandHeroControl ships from main-030 — 88x88 logo badge,
                 "Mockingbird" 40pt ExtraBold, version tag in
                 BrandDeepMutedBrush, and the signed-off tagline beneath. -->
            <controls:BrandHeroControl Tagline="Local voices for Claude Code" />

            <!-- ═══════ 2. Profile & Contact card ═══════
                 Mirrors WhisperHeim's Profile & Contact card. Same 140x140
                 ringed portrait, same Get-in-Touch rows; bio paragraph 1 is
                 verbatim from WhisperHeim, paragraph 2 is the
                 mockingbird-specific voice-diversity line per the task spec. -->
            <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="12" Padding="28" Margin="0,0,0,32">
                <StackPanel>
                    <!-- Profile section: portrait + bio -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Round 140x140 portrait — identical ring to WhisperHeim -->
                        <Border Grid.Column="0" Width="140" Height="140"
                                CornerRadius="70" Margin="0,0,24,0"
                                VerticalAlignment="Top"
                                BorderThickness="3" BorderBrush="#FF25abfe">
                            <Border.Background>
                                <ImageBrush ImageSource="pack://application:,,,/assets/people/heimeshoff.jpg"
                                            Stretch="UniformToFill" />
                            </Border.Background>
                            <Border CornerRadius="70" />
                        </Border>

                        <!-- Bio — paragraph 1 verbatim from WhisperHeim, paragraph 2
                             mockingbird-specific (voice-diversity story). -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="16" TextWrapping="Wrap" LineHeight="24"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,0,12">
                                <Run Text="Hi, I'm " />
                                <Run Text="Marco Heimeshoff" FontWeight="Bold" Foreground="#FF25abfe" />
                                <Run Text=" - trainer, consultant, and conference organiser focused on " />
                                <Run Text="Domain-Driven Design" FontWeight="Bold" Foreground="#FF25abfe" />
                                <Run Text=" and " />
                                <Run Text="collaborative modeling" FontWeight="Bold" Foreground="#FF25abfe" />
                                <Run Text="." />
                            </TextBlock>

                            <TextBlock FontSize="13" TextWrapping="Wrap" LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="I built " /><Run Text="Mockingbird" FontStyle="Italic" /><Run Text=" so my Claude Code sessions could speak in different voices &#x2014; local, offline, with whatever voices I want to clone." />
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Margin="0,0,0,24"
                            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                    <!-- Get in Touch -->
                    <TextBlock Text="Get in Touch"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock Margin="0,0,0,16" FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text="If you'd like to " /><Run Text="learn more about my trainings or consulting work" FontWeight="Bold" /><Run Text=", feel free to reach out:" />
                    </TextBlock>

                    <StackPanel>
                        <!-- Website (heimeshoff.de) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Globe24" FontSize="20" Margin="0,0,12,0"
                                           Foreground="#FF25abfe" VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                                           NavigateUri="https://heimeshoff.de"
                                           Foreground="#FF25abfe" TextDecorations="None">
                                    <Run Text="heimeshoff.de" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Bluesky (official butterfly path lifted verbatim from WhisperHeim) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#1185fe"
                                          Data="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                                           NavigateUri="https://bsky.app/profile/heimeshoff.de"
                                           Foreground="#FF25abfe" TextDecorations="None">
                                    <Run Text="@Heimeshoff.de" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- LinkedIn (glyph lifted verbatim from WhisperHeim) -->
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#0A66C2"
                                          Data="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                                           NavigateUri="https://linkedin.com/in/heimeshoff"
                                           Foreground="#FF25abfe" TextDecorations="None">
                                    <Run Text="linkedin.com/in/heimeshoff" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════ 3. Support & GitHub card ═══════
                 Ko-fi gradient button + GitHub link. URLs come from
                 AppInfo.KofiUrl / AppInfo.GithubUrl so a future move only
                 edits the constant. -->
            <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="12" Padding="28" Margin="0,0,0,32">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="If you enjoy Mockingbird and want to support my open-source work, you can buy me a coffee!"
                               FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />

                    <!-- Ko-fi gradient button — same #FF25abfe → #FF005FAA gradient
                         WhisperHeim uses; click handler in code-behind opens
                         AppInfo.KofiUrl in the default browser. -->
                    <Button x:Name="KofiButton" Click="KofiButton_Click"
                            HorizontalAlignment="Center" Cursor="Hand"
                            Margin="0,0,0,16" Padding="24,12">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="KofiBd" CornerRadius="10"
                                                    Padding="{TemplateBinding Padding}"
                                                    Cursor="Hand">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#FF25abfe" Offset="0" />
                                                        <GradientStop Color="#FF005FAA" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="KofiBd" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Buy me a coffee on Ko-fi"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16">
                        <Run Text="Otherwise, just " /><Run Text="enjoy using Mockingbird for free" FontWeight="Bold" /><Run Text=" &#x2014; and thanks for giving it a try!" />
                    </TextBlock>

                    <!-- GitHub link — points at the mockingbird repo, not WhisperHeim's -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Star24" FontSize="18" Margin="0,0,8,0"
                                       Foreground="#FF25abfe" VerticalAlignment="Center" />
                        <TextBlock VerticalAlignment="Center">
                            <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                                       NavigateUri="https://github.com/heimeshoff/mockingbird"
                                       Foreground="#FF25abfe" TextDecorations="None">
                                <Run Text="View on GitHub" FontWeight="Medium" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════ 4. Credits ═══════ -->
            <TextBlock FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16">
                <Run Text="Synthesis powered by " /><Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                                                               NavigateUri="https://kyutai-labs.github.io/pocket-tts/"
                                                               Foreground="#FF25abfe" TextDecorations="None"><Run Text="pocket-tts" /></Hyperlink><Run Text=" (Kyutai Labs)." />
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</Page>
