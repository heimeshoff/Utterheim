<Page x:Class="Mockingbird.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Mockingbird.ViewModels.Pages"
      Title="About">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <vm:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter" />
        <vm:EngineStateToPipBrushConverter x:Key="EngineStateToPipBrushConverter" />
    </Page.Resources>

    <ScrollViewer Background="{DynamicResource ApplicationBackgroundBrush}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,36,40,32"
                    MaxWidth="900"
                    HorizontalAlignment="Center">

            <!-- ─── 1. Brand mark + identity ──────────────────────────────── -->
            <StackPanel HorizontalAlignment="Center"
                        Margin="0,16,0,32">
                <Image Source="pack://application:,,,/assets/branding/mockingbird-logo-256.png"
                       Width="128" Height="128"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" />
                <TextBlock Text="Mockingbird"
                           FontSize="28"
                           FontWeight="Light"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
                <TextBlock Text="Local voices for Claude Code"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- ─── 2. Version ────────────────────────────────────────────── -->
            <TextBlock HorizontalAlignment="Center"
                       Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="12">
                <Run Text="Version " />
                <Run Text="{Binding ViewModel.Version, Mode=OneWay, FallbackValue='unknown'}" />
            </TextBlock>

            <!-- ─── 3. Engine status panel ────────────────────────────────── -->
            <ui:CardControl Margin="0,0,0,16">
                <ui:CardControl.Header>
                    <TextBlock Text="Engine status"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </ui:CardControl.Header>
                <StackPanel HorizontalAlignment="Stretch"
                            MinWidth="320">

                    <!-- State row: pip + label -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="State"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource EngineStateToPipBrushConverter}">
                                        <Binding Path="ViewModel.EngineState" />
                                        <Binding Path="ViewModel.Healthy" />
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding ViewModel.EngineStateLabel, FallbackValue='—'}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Port row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Port"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ViewModel.PortLabel, FallbackValue='—'}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Healthy row (only visible while Running) -->
                    <Grid Margin="0,0,0,8"
                          Visibility="{Binding ViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Healthy"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="CheckmarkCircle24"
                                       FontSize="16"
                                       Foreground="#10B981"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ViewModel.Healthy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="DismissCircle24"
                                       FontSize="16"
                                       Foreground="#FFE81224"
                                       VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.Healthy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Grid>

                    <!-- Last error block (visible when LastError is non-null) -->
                    <Border BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8"
                            Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                            Visibility="{Binding ViewModel.LastError, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                        <StackPanel>
                            <TextBlock Text="Last error"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding ViewModel.LastError}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Restart button -->
                    <ui:Button Appearance="Primary"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding ViewModel.RestartEngineCommand}"
                               IsEnabled="{Binding ViewModel.IsRetryEnabled, FallbackValue=False}"
                               HorizontalAlignment="Left"
                               Margin="0,4,0,0">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <ui:ProgressRing IsIndeterminate="True"
                                                 Width="14" Height="14"
                                                 Margin="0,0,8,0"
                                                 Visibility="{Binding ViewModel.RestartEngineCommand.IsRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                                <TextBlock Text="Restart Engine" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>
                </StackPanel>
            </ui:CardControl>

            <!-- ─── 4. View logs ──────────────────────────────────────────── -->
            <ui:HyperlinkButton Content="View logs"
                                Command="{Binding ViewModel.OpenLogsCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,24" />

            <!-- ─── 5. Credits ────────────────────────────────────────────── -->
            <TextBlock Text="Synthesis powered by pocket-tts (Kyutai Labs)."
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

        </StackPanel>
    </ScrollViewer>
</Page>
