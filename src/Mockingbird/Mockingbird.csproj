<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Platforms>x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <GarbageCollectionAdaptationMode>0</GarbageCollectionAdaptationMode>
    <RootNamespace>Mockingbird</RootNamespace>
    <AssemblyName>mockingbird</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <StartupObject>Mockingbird.EntryPoint</StartupObject>
    <ApplicationIcon>..\..\assets\branding\mockingbird.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Tray + window brand mark. Linked from the central brand asset folder
         so the source of truth stays in assets\branding\. Generated by
         Tools\RasteriseLogo. -->
    <Resource Include="..\..\assets\branding\mockingbird.ico"
              Link="Resources\mockingbird.ico" />
    <!-- About page brand mark (main-017). 256-px raster scaled down to 128 by
         the page; HighQuality bitmap scaling keeps it crisp on 100/200% DPI. -->
    <Resource Include="..\..\assets\branding\mockingbird-logo-256.png"
              Link="assets\branding\mockingbird-logo-256.png" />
    <!-- Marco's portrait for the About page profile card (main-032). Sourced
         from WhisperHeim's identical portrait so the two apps stay in sync;
         rendered as a 140x140 ringed Border via ImageBrush. -->
    <Resource Include="..\..\assets\people\heimeshoff.jpg"
              Link="assets\people\heimeshoff.jpg" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Remove="App.xaml" />
    <Page Include="App.xaml" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="WPF-UI" Version="3.*" />
    <PackageReference Include="WPF-UI.Tray" Version="3.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.*" />
    <PackageReference Include="NAudio" Version="2.*" />
    <PackageReference Include="Serilog" Version="4.*" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.*" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.*" />
    <PackageReference Include="Serilog.Extensions.Hosting" Version="9.*" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.*" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- Bundle the mockingbird-owned Python sidecar wrapper (ADR 0015 / main-015)
         next to the binary. PythonRuntimeBootstrapper copies the package into the
         bootstrapped Python runtime's site-packages on first launch. -->
    <Content Include="PythonSidecar\mockingbird_sidecar\**\*.py">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>PythonSidecar\mockingbird_sidecar\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>

</Project>
